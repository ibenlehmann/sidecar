---
import Layout from "../layouts/Layout.astro";
---
 <header class="header">
  <nav class="menu">

    <div class="nav-gruppe">
      <a href="/menukort">Menu</a>
      <a href="/">Book bord</a>
      <a href="/selskaber">Selskaber</a>
    </div>

    <a href="/index" class="logo">Sidecar</a>

    <div class="nav-gruppe right">
      <a href="/">Gavekort</a>
      <a href="/cocktailcatering">Cocktail catering</a>
      <a href="/">Aftenbar</a>
    </div>

  </nav>
</header>



      <style>




 .header {
    background: #262d63;
    padding: 28px 60px;
    

  }

  .menu {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .nav-gruppe {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
  }

  .right {
    justify-content: flex-end;
  }

  a {
    color: white;
    text-decoration: none;
    font-size: 10px;
    font-weight: 400;
    transition: opacity 0.2s ease;
  }

  a:hover {
    opacity: 0.7;
  }

  .logo {
    font-size: 14px;
    
    line-height: 1;
    white-space: nowrap;

    
   font-family: "Gloock", serif;
  font-weight: 400;
  }

@media (min-width: 768px) 
{

 .header {
    background: #262d63;
    padding: 28px 60px;
  }

  .menu {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }

  .nav-gruppe {
    display: flex;
    align-items: center;
    gap: 40px;
    flex: 1;
  }

  .right {
    justify-content: flex-end;
  }

  a {
    color: white;
    text-decoration: none;
    font-size: 20px;
    font-weight: 400;
    transition: opacity 0.2s ease;
  }

  a:hover {
    opacity: 0.7;
  }

  .logo {
    font-size: 55px;
    
    line-height: 1;
    white-space: nowrap;

    
   font-family: "Gloock", serif;
  font-weight: 400;
  }
}

      </style>

      
---
const { mad } = Astro.props;
---

<div class="menu_mad" id="basket">
   <p class="p_special_bold">{mad.navn}</p>
   <p class="p_special">{mad.beskrivelse}</p>
</div>
  

   <style>
       h2, p{
       color: var(--color-secondary);
      }

      .p_special_bold{
         font-size: 18px;
         font-weight: 600;
         margin-bottom: 0;
         margin-top: 2rem;
      }

      .p_special{
         margin-top: 0;
      }

      .menu_mad{
         text-align: center;
         max-width: 380px;
         justify-self: center;
      }

      @media (min-width: 800px){
         .p_special_bold{
         font-size: 25px;
         
      }

      .p_special{
         margin-top: 2px;
         font-size: 20px;
      }

      .menu_mad{
         max-width: 800px;
         padding: 0.1rem 0;
         
      }

      }

      /* animationer */
   /**** med id basket, bliver synlig når man scroller ***/

 #basket {
   animation: clip-reveal-top ease-in-out both;
   animation-timeline: view();
   animation-range: 10% 30%;
  }

 @keyframes clip-reveal-top {
  from {
    opacity: 0;
    clip-path: inset(0 0 100% 0);
  }
  to {
    opacity: 1;
    clip-path: inset(0 0 0 0);
  }
 }
   </style>
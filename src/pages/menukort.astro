---
//@ts-nocheck
import Layout from "../layouts/Layout.astro";
import Menumad from "../components/Menumad.astro";
import Coffee from "../components/Coffee.astro";
import Tea from "../components/Tea.astro";
import Brunchdrinks from "../components/Brunchdrinks.astro";
import Colddrinks from "../components/Colddrinks.astro";
import Matcha from "../components/Matcha.astro";
import Other from "../components/Other.astro";
import Wine from "../components/Wine.astro";
import Beer from "../components/Beer.astro";


const apiKey = "sb_publishable_Ik-Cm_IdDH9hqrY-8tragg_fTz_0YjC";

const options = {
  headers: {
    apikey: apiKey,
  },
};

/* kaffe */
const kaffe = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/coffee?select=*", options).then((res) => res.json());

/* Tea */
const tea = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/tea?select=*", options).then((res) => res.json());

/* Beer */
const beer = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/beer?select=*", options).then((res) => res.json());

/* Brunch drinks */
const brunchdrinks = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/brunchDrinks?select=*", options).then((res) => res.json());

/* cold drinks */
const cold = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/coldDrinks?select=*", options).then((res) => res.json());

/* matcha */
const matcha = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/matcha?select=*", options).then((res) => res.json());

/* other */
const other = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/other?select=*", options).then((res) => res.json());

/* wine */
const wine = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/wine?select=*", options).then((res) => res.json());

/* menu mad */
const mad = await fetch("https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/menuMad?select=*", options).then((res) => res.json());

---


<Layout title="Menukort">
  <body>
    <section id="top" class="hero">
   <h1>Menu</h1>
   <p class="p_1"> Der bliver serveret fra kl. 9-15 hver dag.</p>
   <p class="vg">Veganske retter = vg</p>
   <div class="knapper">
    <a href="#drikkevarer" class="btn">Se drikkevarer</a>
   <a href="#priser" class="btn">Se brunch priser</a>
   </div>
   <button class="book_btn"> Book Bord </button>
  </section>

  <section class="menu_mad">
    
      <div class="menu_mad1">
         <h3>Brunch</h3>
         <p>Vælg hver 4 muligheder.</p>
         {mad.map((mad) => <Menumad mad={mad} />)}
      </div>

      <div id="priser" class="kasse_other_img">
        <div class="bla_kasse">
          <h4>Brunch priser</h4>

          <div class="bla_kasse1">
           <div class="row">
             <p>Weekend</p>
             <p>Hverdage</p>
             <p>Børn (3–12år)</p>
           </div>

           <div class="row">
             <p>209 kr.</p>
             <p>189 kr.</p>
             <p>halv pris.</p>
           </div>
           </div>
        </div>
        <div class="menu_other">
         <h3>Other</h3>
         <p>Tilgænglig man-fredag kl. 8-15.</p>
          {other.map((other) => <Other other={other} />)}
        </div>
        
        <img src="/img/croissant.webp" alt="croissant">
      </div>

  </section>

  <section class="drikke_1">
    <h2 id="drikkevarer">Drikkevarer</h2>
    <div class="drikke_1_2">
      <div class="coffee">
        <h3>Coffee and such</h3>
        <p>Specialty coffee from Copenhagen</p>
        {kaffe.map((kaffe) => <Coffee kaffe={kaffe} />)}
      </div>
      <div class="tea_matcha">
        <div class="tea">
          <h3>Tea</h3>
          <p>Organic tea from ‘les jardins de gaïa’.</p>
          {tea.map((tea) => <Tea tea={tea} />)}
        </div>
        <div class="matcha">
          <h3>Matcha</h3>
          <p>From SATO CPH</p>
          {matcha.map((matcha) => <Matcha matcha={matcha} />)}
        </div>
        
       
      </div>
    </div>
    

  </section>

  <section class="drikke_2">
    <div>
      <div class="cold">
       <h3>Cold drinks</h3>
       {cold.map((cold) => <Colddrinks cold={cold} />)}
     </div>
      <div class="drinks">
       <h3>Brunch drinks</h3>
       {brunchdrinks.map((brunchdrinks) => <Brunchdrinks brunchdrinks={brunchdrinks} />)}
      </div>
    </div>

     <div>
      <div class="wine">
       <h3>Wine</h3>
       <p>Ask to see the list</p>
        {wine.map((wine) => <Wine wine={wine} />)}
     </div>
      <div class="beer">
       <h3>Beer</h3>
        {beer.map((beer) => <Beer beer={beer} />)}
        <img src="/img/kop.webp" alt="kop">
      </div>
    </div>
    
  </section>
  <a href="#top" class="top_btn">↑</a>
 
    
  </body>

</Layout>



<style>
  h1, h2, h3, p{
    color: var(--color-secondary);
  }


  /************ hero sektion ************/
  .hero{
   display: flex;
   flex-direction: column;
   align-items: center;
   padding: 2rem 0;
   margin: 0 2.5rem;
    
  }

  .p_1{
    margin-top: 5px;
    margin-bottom: 0;
  }

  .vg{
    margin-top: 2px;
    margin-bottom: 3rem;
  }

  .hero h1{
    margin-bottom: 0;
  }

  /************ Menuer ************/
  .menu_mad1 p,
  .menu_other p,
  .coffee p,
  .tea p,
  .matcha p,
  .wine p{
    border-bottom: 1px solid var(--color-black);
    margin: 0;
    padding-bottom: 5px;
  }

  .menu_mad1,
  .menu_other,
  .coffee,
  .tea,
  .matcha,
  .cold,
  .drinks,
  .wine,
  .beer{
    margin: 0 4rem;
  }

  .menu_mad1 h3,
  .coffee h3{
    margin-bottom: 0;
    margin-top: 35px;
  }


  .menu_other h3,
  .tea h3,
  .matcha h3,
  .wine h3{
    margin-bottom: 0;
    margin-top: 80px;
  }

  .cold h3,
  .drinks h3,
  .beer h3{
    border-bottom: 1px solid var(--color-black);
    margin: 80px 0 0 0;
    padding-bottom: 5px;
  }



  /************ Blå kasse ************/
  .bla_kasse{
    background-color: var(--color-secondary);
    margin: 62px auto 4rem;
    padding: 2rem;
    max-width: 350px;
    
  }

  .bla_kasse1{
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-items: center;
   
  }

  .bla_kasse h4{
    margin: 0 0 1rem 0;
  }

  .row p{
    color: var(--color-primary);
    margin: 0 0 5px;
  } 

  /************ drikkevarer ************/
  .drikke_1 h2{
    justify-self: center;
    margin: 7rem 0 2rem;
  }

  .drikke_2{
    margin-bottom: 5rem;
  }

  #drikkevarer {
  border-bottom: 3px solid var(--color-secondary);
  padding-bottom: 1px;
}

  /*********** IMG ***********/
  img{
    width: 50%;
    justify-self: center;
    margin: 2rem 0;
  }

  /************ KNAPPER ************/

  .btn{
    justify-self: center;
  }


.knapper{
  display: flex;
  justify-content: center;
  gap: 1rem;
}

.top_btn{
  display: flex;
  justify-content: center;
  align-items: center;
  justify-self: center;
  text-decoration: none;
  font-size: 25px;
  background-color: var(--color-action);
  color: var(--color-white);
  width: 50px;
  height: 50px;
  border-radius: 50%;
  margin: 2rem 0 5rem;
}

.top_btn:hover{
	background-color: #a84f40;
}



 /* DESKTOP */
  @media (min-width: 800px){

    /* hero */
    .hero{
   padding: 4rem 0;
   margin: 0 5rem;
    
  }

  .vg{
    margin-bottom: 5rem;
  }

  /* blå kasse*/
  .bla_kasse{
    margin: 62px 2rem 4rem;
    padding: 3rem;
    max-width: 550px;
  }

   .bla_kasse1{
    gap: 4rem;
    justify-self: center;
   
   }

  /* menu flere sektioner*/
  .menu_mad1,
  .coffee,
  .cold,
  .drinks{
    margin-left: 5rem;
    margin-right: 2rem;
  }

  .tea,
  .menu_other,
  .matcha,
  .wine,
  .beer{
    margin-left: 2rem;
    margin-right: 5rem;
  
  }

  .matcha h3,
  .wine h3,
  .beer h3,
  .cold h3,
  .drinks h3{
    margin-top: 85px;
  }

  /* menu flex */

  .menu_mad,
  .drikke_1_2,
  .drikke_2{
    display: grid;
  grid-template-columns: 1fr 1fr;
  }

 /* drikke*/
  .drikke_1 h2{
    margin: 14rem 0 4rem;
  }

  /* IMG */
  img{
    margin: 5rem 0 0;
    
  }

  .top_btn{
  font-size: 40px;
  width: 70px;
  height: 70px;
 }


  }

  
</style>
---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Menukort drikkevarer">
  <section class="hero">
   <h1>Menu</h1>
   <p>Vi har åbent kl 9-16 hver dag. <br>
      Køkkenet lukker kl 15. 
   </p>

    <div class="hero_tabs">
      <a  href="/menukort">MAD</a>
      <a class="drikke" href="/menukort_drik">DRIKKE</a>
    </div>
  </section>

  <button class="book_btn"> Book Bord </button>

  <section class="section_2">
    <h2>Drikkevarer</h2>
    <div class="coffee" >
        <p class="p_bold" >Coffee, tea and such</p>
        <p class="less_gap_2" >specialty coffee from Copenhagen</p>
        <p >Coffee Lab filter 30 kr. - refill 15 kr.<br>
         Espresso 32 kr.<br>
         Americano 34 kr.<br>
         Iced americano 34 kr.<br>
         Cortado 37 kr.<br>
         Flat white 40 kr.<br>
         Cappuccino 42 kr.<br>
         Latte 42 kr.<br>
         Iced latte 45 kr.<br>
         Chai latte 45 kr.<br>
         Hot chocolate 45 kr.
         
        </p>
        <p class="less_gap">Tea 45 kr.<br> organic tea from ‘les jardins de gaïa’ 
        choose between:<br>
        green / white / herbal / earl grey / breakfast
        </p>
    </div>

    <div >
        <p class="p_bold">Matcha from SATO CPH </p>
        <p class="less_gap_2">
            Matcha latte 49 kr.<br>
            Matcha tea 47 kr.<br>
            Iced matcha latte 49 kr.
        </p>
    </div>

    <div >
        <p class="p_bold">Brunch drinks</p>
        <p class="less_gap_2">Mimosa 75 kr.<br> orange juice and cava brut </p>
        <p>Mimosa kit 420 kr.<br> a bottle of cava and a pitcher of orange juice </p>
        <p>Bloody mary 80 kr.<br> vodka, tabasco, spices and tomato juice</p>
    </div>

    <div >
        <p class="p_bold">Cold drinks</p>
        
        <p class="less_gap_2">Green juice 45 kr.<br>
            Orange juice 45 kr.<br>
          Apple juice 45 kr. <br>

          Classic lemonade 42 kr.<br> 

          Lemongrass lemonade 42 kr.<br>

          Ginger beer / cola / zero 35 kr.<br> 

          Sparkling water bottle 20 kr.
        </p>
    </div>

    <div >
        <p class="p_bold">Wine</p>
        <p class="less_gap">Ask to see wine list</p>
        <p class="less_gap_2">Bubbles, white, orange and red by the glass 70 kr. <br>Bottles from 340 kr.</p>

    </div>

    <div class="beer">
        <p class="p_bold">Beer</p>
        <p class="less_gap_2">
            45 days organic pilsner, to øl 35 / 50 kr.<br>
            Wheat in motion, to øl 40 / 60 kr.<br>
            Berry barrage, to øl 40 / 60 kr.<br>
            Whirl domination, to øl 40 / 60 kr.<br>
            Special effects lager 0,4%, brooklyn brewery 50 kr.<br>
            Implosion ipa 0,3%, to øl 55 kr.
        </p>

    </div>


  </section>

</Layout>


<style>
    h1, h2, p{
    color: var(--color-secondary);
  }

  /* hero sectionen med knap */
  .hero{
   display: flex;
   flex-direction: column;
   align-items: center;
   justify-content: center;
   margin: 3rem 0 2.5rem;
   border-bottom: 0.5px solid var(--color-black);
  }

  .hero p{
    text-align: center;
    margin-top: -5px;
  }

  .hero_tabs {
    display: flex;
    gap: 2rem;
    padding-top: 1.5rem;
    padding-bottom: 2.5rem;
  }

  .hero_tabs a{
    font-size: 20px;
    font-family: "Gloock", serif;
    font-weight: 400;
    text-decoration: none;
    color: var(--color-secondary);
  }

  .hero_tabs a:visited{
    color: var(--color-secondary);
     text-decoration: none;
  }

  .hero_tabs a.drikke,
  .hero_tabs a.drikke:visited {
  text-decoration: underline;
  text-underline-offset: 5px;
}

  .book_btn {
    position: fixed;
    top: 30%;
    right: 0;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: right center;
    margin-right: 1rem;
    border-radius: 15px 15px 0 0;
    z-index: 100;
  }

  /* section 2 */
  h2{
    justify-self: center;
  }
  .section_2 div{
    display: flex;
   flex-direction: column;
   align-items: center;
   text-align: center;
   margin: 2rem 0;
  }

  .p_bold{
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .less_gap{
    margin-top: -14px;
  }

  .less_gap_2{
    margin-top: -10px;
  }

  .beer{
    padding-bottom: 5rem;
  }


  /* DESKTOP */

   @media (min-width: 800px){
    /* sektion 1 hero */
    .hero{
     margin: 5rem 0 6rem;
    }

    .hero_tabs{
    gap: 5rem;
    padding-top: 3rem;
  }

  .hero_tabs a{
    font-size: 30px;
   padding-bottom: 4rem;
  }

   /* KNAP */
   .book_btn {
    top: 60%;
    margin-right: 1.5rem;
  }

  /* section 2*/

  h2{
    margin-bottom: -1rem;
  }

  .p_bold{
    font-size: 25px;
  }

  .section_2 div{
     margin: 4rem 0;
  }
   }


</style>